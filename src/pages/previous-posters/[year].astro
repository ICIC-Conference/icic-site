---
import MainLayout from "../../layouts/MainLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posters = await getCollection("posters");
  const years = [...new Set(posters.map((poster) => poster.data.year))];
  return years.map((year) => ({
    params: { year: String(year) },
  }));
}

const { year } = Astro.params;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allPosters = await getCollection("posters");

const posters = allPosters.filter(
  (poster) => String(poster.data.year) === String(year)
);

const divisionLabels = {
  university: "University",
  highschool: "High School",
};

const prizeImages = {
  "1st": "/images/medals/1st.png",
  "2nd": "/images/medals/2nd.png",
  "3rd": "/images/medals/3rd.png",
  "4th": "/images/medals/4th.png",
  "5th": "/images/medals/5th.png",
};

const prizeOrder = ["1st", "2nd", "3rd", "4th", "5th"];

function posterSortKey(p) {
  const divisionRank = p.data.division === "highschool" ? 0 : 1;
  const prizeRank = p.data.prize ? prizeOrder.indexOf(p.data.prize) : 99;
  const sortOrder = p.data.sortOrder ?? 9999;
  return [divisionRank, prizeRank, sortOrder];
}

const groupedByCategory = posters.reduce((acc, poster) => {
  const category = poster.data.category;
  if (!acc[category]) acc[category] = [];
  acc[category].push(poster);
  return acc;
}, {});

for (const category in groupedByCategory) {
  groupedByCategory[category].sort((a, b) => {
    const aKey = posterSortKey(a);
    const bKey = posterSortKey(b);
    for (let i = 0; i < aKey.length; i++) {
      if (aKey[i] !== bKey[i]) return aKey[i] - bKey[i];
    }
    return 0;
  });
}

const categoryOrder = [
  "Research",
  "Social Issues",
  "Business & Social Sciences",
  "Expository",
  "International Perspectives",
  "Natural & Environmental Sciences",
  "Creative/Video",
  "Academic Topics",
  "Arts & Humanities",
  "Multimedia Videos",
];

const categories = [
  ...categoryOrder.filter((c) => groupedByCategory[c]),
  ...Object.keys(groupedByCategory).filter((c) => !categoryOrder.includes(c)),
];

function slugify(str) {
  return str.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "");
}
---

<MainLayout title={`Posters – ${year}`}>
  <style>
    .page-body {
      background: var(--cream);
    }

    .page-hero {
      background: var(--navy);
      background-size: cover;
      background-position: center;
      padding: 56px 56px 48px;
      min-height: 220px;
      position: relative;
    }

    .page-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(27, 51, 82, 0.72);
    }

    .page-hero .section-label,
    .page-hero h2 {
      position: relative;
      z-index: 1;
    }

    .page-hero h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 3rem;
      font-weight: 600;
      color: var(--white);
      margin: 0;
      line-height: 1.25;
    }

    .content-section {
      padding: 56px;
    }

    /* Jump nav */
    .category-nav {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 48px;
      padding-bottom: 32px;
      border-bottom: 1px solid var(--rule);
    }

    .category-nav a {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--navy);
      text-decoration: none;
      padding: 6px 14px;
      border: 1px solid var(--navy);
      border-radius: 3px;
      transition: background 0.15s, color 0.15s;
    }

    .category-nav a:hover {
      background: var(--navy);
      color: var(--white);
    }

    .category-section {
      margin-bottom: 56px;
      scroll-margin-top: 80px;
    }

    .category-heading {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin: 0 0 24px 0;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--rule);
    }

    .category-heading h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.6rem;
      font-weight: 600;
      color: var(--navy);
      margin: 0;
    }

    .back-to-top {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--gold);
      text-decoration: none;
      letter-spacing: 0.04em;
      white-space: nowrap;
      flex-shrink: 0;
      margin-left: 16px;
    }

    .back-to-top:hover {
      color: var(--navy);
    }

    .poster-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 220px));
      gap: 20px;
      justify-content: start;
    }

    .poster-image-link {
      display: block;
      text-decoration: none;
      color: inherit;
    }

    .poster-thumb-wrap {
      position: relative;
      width: 100%;
      aspect-ratio: 0.72 / 1;
      overflow: hidden;
      border: 1px solid #ccc;
      background: #f8f8f8;
    }

    .poster-thumb {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .poster-medal {
      position: absolute;
      bottom: 10px;
      right: 10px;
      height: 64px;
      z-index: 2;
    }

    .poster-overlay {
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.72);
      color: white;
      padding: 16px;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      opacity: 0;
      transition: opacity 0.2s ease;
      z-index: 1;
    }

    .poster-thumb-wrap:hover .poster-overlay,
    .poster-thumb-wrap:focus-within .poster-overlay {
      opacity: 1;
    }

    .poster-overlay h4 {
      margin: 0 0 8px 0;
      font-size: 1rem;
      line-height: 1.3;
    }

    .poster-overlay p {
      margin: 0 0 6px 0;
      font-size: 0.9rem;
      line-height: 1.3;
    }

    .poster-video-button {
      display: inline-block;
      align-self: flex-start;
      width: auto;
      margin-top: 10px;
      padding: 6px 10px;
      font-size: 0.85rem;
      background: #cc0000;
      color: white;
      text-decoration: none;
      border-radius: 4px;
      white-space: nowrap;
    }

    .poster-video-button:hover {
      background: #a80000;
    }

    @media (max-width: 860px) {
      .page-hero {
        padding: 40px 28px 36px;
      }

      .content-section {
        padding: 40px 28px;
      }
    }
  </style>

  <div class="page-body">
    <div class="page-hero" id="top" style={`background-image: url('${base}/images/site/hero-posters.jpg')`}>
      <h2>Posters – {year}</h2>
    </div>

    <div class="content-section">

      {categories.length > 1 && (
        <nav class="category-nav">
          {categories.map((category) => (
            <a href={`#${slugify(category)}`}>{category}</a>
          ))}
        </nav>
      )}

      {categories.length === 0 ? (
        <p>No posters found for this year.</p>
      ) : (
        categories.map((category) => (
          <section class="category-section" id={slugify(category)}>
            <div class="category-heading">
              <h3>{category}</h3>
              <a href="#top" class="back-to-top">↑ Back to top</a>
            </div>

            <div class="poster-grid">
              {groupedByCategory[category].map((poster) => (
                <div class="poster-card">
                  <a
                    href={`${base}${poster.data.posterImage}`}
                    class="poster-image-link"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <div class="poster-thumb-wrap">
                      <img
                        src={`${base}${poster.data.posterImage}`}
                        alt={poster.data.title}
                        class="poster-thumb"
                      />

                      {poster.data.prize && prizeImages[poster.data.prize] ? (
                        <img
                          src={`${base}${prizeImages[poster.data.prize]}`}
                          alt={`${poster.data.prize} prize`}
                          class="poster-medal"
                        />
                      ) : null}

                      <div class="poster-overlay">
                        <h4>{poster.data.title}</h4>
                        <p>{poster.data.authors.join(", ")}</p>
                        <p>{divisionLabels[poster.data.division] ?? poster.data.division}</p>

                        {poster.data.videoUrl ? (
                          <a
                            href={poster.data.videoUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="poster-video-button"
                            onclick="event.stopPropagation();"
                          >
                            ▶ Watch Video
                          </a>
                        ) : null}
                      </div>
                    </div>
                  </a>
                </div>
              ))}
            </div>
          </section>
        ))
      )}

    </div>
  </div>
</MainLayout>