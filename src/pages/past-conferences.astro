---
import MainLayout from "../layouts/MainLayout.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allConferences = await getCollection("conferences");
const conferences = allConferences.sort((a, b) => b.data.year - a.data.year);
---

<MainLayout title="Past Conferences">
  <style>
    .page-body {
      background: var(--cream);
    }

    .page-hero {
  background: var(--navy);
  background-image: url('/images/site/hero-past-conferences.jpg');
  background-size: cover;
  background-position: center;
  padding: 56px 56px 48px;
  min-height: 220px;
  position: relative;
}

    .page-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(27, 51, 82, 0.72);
    }

    .page-hero h2 {
      position: relative;
      z-index: 1;
      font-family: 'Cormorant Garamond', serif;
      font-size: 3rem;
      font-weight: 600;
      color: var(--white);
      margin: 0;
      line-height: 1.25;
    }

    .content-section {
      padding: 56px;
    }

    .conference-entry {
      border-bottom: 1px solid var(--rule);
      padding-bottom: 56px;
      margin-bottom: 56px;
    }

    .conference-entry:last-child {
      border-bottom: none;
    }

    .conference-year {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin: 0 0 10px 0;
    }

    .conference-theme {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2rem;
      font-weight: 600;
      color: var(--navy);
      margin: 0 0 20px 0;
      line-height: 1.25;
      max-width: 820px;
    }

    .conference-theme.placeholder {
      color: var(--rule);
      font-style: italic;
    }

    .conference-body {
      display: grid;
      grid-template-columns: 1fr 200px;
      gap: 48px;
      align-items: start;
    }

    .conference-body.no-poster {
      grid-template-columns: 1fr;
    }

    .conference-description {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 1rem;
      line-height: 1.75;
      color: var(--text, #2a2a2a);
      font-weight: 300;
      margin: 0 0 32px 0;
    }

    .keynotes-label {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gold);
      margin: 0 0 16px 0;
    }

    .keynote-list {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .keynote-item {
      display: grid;
      grid-template-columns: 64px 1fr;
      gap: 16px;
      align-items: start;
    }

    .keynote-item.no-image {
      grid-template-columns: 1fr;
    }

    .keynote-photo {
      width: 64px;
      height: 64px;
      object-fit: cover;
      border-radius: 2px;
      display: block;
    }

    .keynote-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.2rem;
      font-weight: 600;
      color: var(--navy);
      margin: 0 0 2px 0;
    }

    .keynote-role {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.85rem;
      color: var(--muted, #6b6b6b);
      font-weight: 300;
      margin: 0 0 4px 0;
    }

    .keynote-talk {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.88rem;
      color: var(--navy);
      font-style: italic;
      margin: 0;
    }

    .poster-wrap {
      position: relative;
    }

    .poster-link {
      display: block;
    }

    .poster-image {
      width: 100%;
      height: auto;
      display: block;
      border: 1px solid var(--rule);
    }

    .poster-caption {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.78rem;
      color: var(--muted, #6b6b6b);
      margin: 8px 0 0 0;
      text-align: center;
    }

    @media (max-width: 860px) {
      .page-hero {
        padding: 40px 28px 36px;
      }

      .content-section {
        padding: 40px 28px;
      }

      .conference-body {
        grid-template-columns: 1fr;
      }

      .poster-wrap {
        max-width: 280px;
      }
    }
  </style>

  <div class="page-body">
    <div class="page-hero">
      <h2>Past Conferences</h2>
    </div>

    <div class="content-section">
      {conferences.map((conf) => (
        <div class="conference-entry">
          <p class="conference-year">ICIC {conf.data.year}</p>

          {conf.data.theme ? (
            <h2 class="conference-theme">{conf.data.theme}</h2>
          ) : (
            <h2 class="conference-theme placeholder">Theme to be added</h2>
          )}

          <div class={`conference-body${conf.data.posterImage ? '' : ' no-poster'}`}>
            <div>
              {conf.data.description && (
                <p class="conference-description">{conf.data.description}</p>
              )}

              {conf.data.keynotes.length > 0 && (
                <div>
                  <p class="keynotes-label">
                    {conf.data.keynotes.length === 1 ? 'Keynote Speaker' : 'Keynote Speakers'}
                  </p>
                  <div class="keynote-list">
                    {conf.data.keynotes.map((k) => (
                      <div class={`keynote-item${k.image ? '' : ' no-image'}`}>
                        {k.image && (
                          <img
                            src={`${base}${k.image}`}
                            alt={k.name}
                            class="keynote-photo"
                          />
                        )}
                        <div>
                          <p class="keynote-name">{k.name}</p>
                          <p class="keynote-role">{k.role}, {k.institution}</p>
                          {k.talkTitle && (
                            <p class="keynote-talk">"{k.talkTitle}"</p>
                          )}
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              )}
            </div>

            {conf.data.posterImage && (
              <div class="poster-wrap">
                <a
                  href={`${base}${conf.data.posterImage}`}
                  class="poster-link"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <img
                    src={`${base}${conf.data.posterImage}`}
                    alt={`ICIC ${conf.data.year} conference poster`}
                    class="poster-image"
                  />
                </a>
                <p class="poster-caption">Conference poster — click to view full size</p>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</MainLayout>
