---
import MainLayout from "../layouts/MainLayout.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allConferences = await getCollection("conferences");
const conferences = allConferences.sort((a, b) => b.data.year - a.data.year);
---

<MainLayout title="Past Conferences">
  <style>
    .page-body {
      background: var(--cream);
    }

    .page-hero {
      background: var(--navy);
      background-image: url('/images/site/hero-past-conferences.jpg');
      background-size: cover;
      background-position: center;
      padding: 56px 56px 48px;
      min-height: 220px;
      position: relative;
    }

    .page-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(27, 51, 82, 0.72);
    }

    .page-hero h2 {
      position: relative;
      z-index: 1;
      font-family: 'Cormorant Garamond', serif;
      font-size: 3rem;
      font-weight: 600;
      color: var(--white);
      margin: 0;
      line-height: 1.25;
    }

    .content-section {
      padding: 56px;
    }

    .conference-entry {
      border-bottom: 1px solid var(--rule);
      padding-bottom: 56px;
      margin-bottom: 56px;
    }

    .conference-entry:last-child {
      border-bottom: none;
    }

    .conference-year {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin: 0 0 16px 0;
    }

    .conference-body {
      display: grid;
      grid-template-columns: 1fr 160px;
      gap: 48px;
      align-items: start;
    }

    .conference-body.no-poster {
      grid-template-columns: 1fr;
    }

    .conference-theme {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2rem;
      font-weight: 600;
      color: var(--navy);
      margin: 0 0 12px 0;
      line-height: 1.25;
    }

    .conference-theme.placeholder {
      color: var(--rule);
      font-style: italic;
    }

    .program-link {
      display: inline-block;
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--gold);
      text-decoration: none;
      margin: 0 0 20px 0;
      letter-spacing: 0.02em;
    }

    .program-link:hover {
      color: var(--navy);
    }

    .conference-description {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 1rem;
      line-height: 1.75;
      color: var(--text, #2a2a2a);
      font-weight: 300;
      margin: 0;
    }

    .poster-wrap {
      position: relative;
    }

    .poster-link {
      display: block;
    }

    .poster-image {
      width: 100%;
      height: auto;
      display: block;
      border: 1px solid var(--rule);
    }

    .poster-caption {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.78rem;
      color: var(--muted, #6b6b6b);
      margin: 8px 0 0 0;
      text-align: center;
    }

    @media (max-width: 860px) {
      .page-hero {
        padding: 40px 28px 36px;
      }

      .content-section {
        padding: 40px 28px;
      }

      .conference-body {
        grid-template-columns: 1fr;
      }

      .poster-wrap {
        max-width: 200px;
      }
    }
  </style>

  <div class="page-body">
    <div class="page-hero">
      <h2>Past Conferences</h2>
    </div>

    <div class="content-section">
      {conferences.map((conf) => (
        <div class="conference-entry">
          <p class="conference-year">ICIC {conf.data.year}</p>

          <div class={`conference-body${conf.data.posterImage ? '' : ' no-poster'}`}>
            <div>
              {conf.data.theme ? (
                <h2 class="conference-theme">{conf.data.theme}</h2>
              ) : (
                <h2 class="conference-theme placeholder">Theme to be added</h2>
              )}

              {conf.data.programPdf && (
                <a href={`${base}${conf.data.programPdf}`} target="_blank" rel="noopener noreferrer" class="program-link">Conference Program</a>
              )}

              {conf.data.description && (
                <p class="conference-description">{conf.data.description}</p>
              )}
            </div>

            {conf.data.posterImage && (
              <div class="poster-wrap">
                <a
                  href={`${base}${conf.data.posterImage}`}
                  class="poster-link"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <img
                    src={`${base}${conf.data.posterImage}`}
                    alt={`ICIC ${conf.data.year} conference poster`}
                    class="poster-image"
                  />
                </a>
                <p class="poster-caption">Conference poster — click to view full size</p>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</MainLayout>