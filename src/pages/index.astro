---
import MainLayout from "../layouts/MainLayout.astro";
import homepageData from "../data/homepage";

const { hero, theme, keynote, schedule, importantDates, documents, sponsors, footer } = homepageData;
---

<MainLayout title="ICIC 2026">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Source+Sans+3:wght@300;400;500;600&display=swap');

    :root {
      --navy: #1b3352;
      --gold: #b8882a;
      --gold-light: #e8c96a;
      --cream: #f8f6f1;
      --text: #2a2a2a;
      --muted: #6b6b6b;
      --rule: #d8d0c0;
      --white: #ffffff;
    }

    * { box-sizing: border-box; }

    .hero {
      position: relative;
      margin-bottom: 0;
      overflow: hidden;
    }

    .hero-image {
      width: 100%;
      height: 520px;
      object-fit: cover;
      display: block;
      filter: brightness(0.75);
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: flex-end;
      background: linear-gradient(
        to top,
        rgba(27, 51, 82, 0.88) 0%,
        rgba(27, 51, 82, 0.4) 50%,
        transparent 100%
      );
      padding: 48px 56px;
    }

    .hero-text { max-width: 780px; }

    .hero-label {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gold-light);
      margin: 0 0 14px 0;
    }

    .hero-text h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.8rem;
      font-weight: 600;
      color: var(--white);
      margin: 0 0 16px 0;
      line-height: 1.15;
    }

    .hero-meta {
      display: flex;
      gap: 24px;
      flex-wrap: wrap;
      margin: 0;
    }

    .hero-meta span {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 1rem;
      color: rgba(255, 255, 255, 0.85);
      font-weight: 300;
      letter-spacing: 0.02em;
    }

    .hero-meta span::before {
      content: '— ';
      color: var(--gold-light);
      opacity: 0.7;
    }

    .page-body {
      background: var(--cream);
      font-family: 'Source Sans 3', sans-serif;
      color: var(--text);
    }

    .section {
      padding: 64px 56px;
      border-bottom: 1px solid var(--rule);
    }

    .section:last-child { border-bottom: none; }

    .section-label {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin: 0 0 10px 0;
    }

    .section h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2rem;
      font-weight: 600;
      color: var(--navy);
      margin: 0 0 28px 0;
      line-height: 1.2;
    }

    .theme-section {
      background: var(--navy);
      color: var(--white);
      padding: 72px 56px;
    }

    .theme-section .section-label {
      color: var(--gold-light);
      opacity: 0.8;
    }

    .theme-section h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.2rem;
      font-weight: 600;
      color: var(--white);
      margin: 0 0 28px 0;
      line-height: 1.25;
      max-width: 820px;
    }

    .theme-section p {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 1.05rem;
      line-height: 1.75;
      color: rgba(255, 255, 255, 0.82);
      max-width: 820px;
      font-weight: 300;
    }

    .theme-rule {
      width: 48px;
      height: 2px;
      background: var(--gold);
      margin: 24px 0;
      border: none;
    }

    .keynote-grid {
      display: grid;
      grid-template-columns: 200px 1fr;
      gap: 40px;
      align-items: start;
    }

    .keynote-image-wrap {
      position: relative;
      width: 200px;
      flex-shrink: 0;
    }

    .keynote-image {
      width: 100%;
      height: auto;
      display: block;
      filter: grayscale(20%);
    }

    .keynote-image-accent {
      position: absolute;
      bottom: -8px;
      right: -8px;
      width: 100%;
      height: 100%;
      border: 2px solid var(--gold);
      z-index: -1;
    }

    .keynote-info { padding-top: 6px; }

    .keynote-info h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.9rem;
      font-weight: 600;
      color: var(--navy);
      margin: 0 0 6px 0;
    }

    .keynote-role {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.92rem;
      color: var(--muted);
      margin: 0 0 20px 0;
      font-weight: 400;
    }

    .keynote-talk-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.35rem;
      font-style: italic;
      color: var(--navy);
      margin: 0 0 18px 0;
      padding-left: 18px;
      border-left: 3px solid var(--gold);
      line-height: 1.4;
    }

    .keynote-description {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 1rem;
      line-height: 1.7;
      color: var(--text);
      font-weight: 300;
      margin: 0;
    }

    .schedule-section { background: var(--white); }

    .schedule-list {
      display: flex;
      flex-direction: column;
      gap: 0;
      border: 1px solid var(--rule);
    }

    .schedule-row {
      display: grid;
      grid-template-columns: 140px 1fr;
      align-items: stretch;
      border-bottom: 1px solid var(--rule);
    }

    .schedule-row:last-child { border-bottom: none; }

    .schedule-time {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--navy);
      padding: 20px;
      background: #f0ede6;
      border-right: 1px solid var(--rule);
      display: flex;
      align-items: center;
      letter-spacing: 0.01em;
    }

    .schedule-columns { display: grid; gap: 0; }

    .schedule-column {
      display: flex;
      flex-direction: column;
      border-right: 1px solid var(--rule);
    }

    .schedule-column:last-child { border-right: none; }

    .schedule-block {
      padding: 18px 22px;
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      border-bottom: 1px solid var(--rule);
    }

    .schedule-block:last-child { border-bottom: none; }

    .schedule-block strong {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--navy);
    }

    .schedule-block p {
      margin: 4px 0 0 0;
      font-size: 0.88rem;
      color: var(--muted);
    }

    .dates-docs-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
    }

    .dates-docs-grid h2 {
      font-size: 1.3rem;
      margin-bottom: 20px;
    }

    .date-item {
      display: flex;
      flex-direction: column;
      padding: 16px 0;
      border-bottom: 1px solid var(--rule);
    }

    .date-item:first-of-type { border-top: 1px solid var(--rule); }

    .date-label {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.88rem;
      color: var(--muted);
      font-weight: 400;
      margin-bottom: 4px;
    }

    .date-value {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--navy);
    }

    .doc-group {
      margin-bottom: 24px;
    }

    .doc-group-label {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--muted);
      margin: 0 0 6px 0;
    }

    .doc-link {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 0;
      border-bottom: 1px solid var(--rule);
      text-decoration: none;
      color: var(--navy);
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.95rem;
      transition: color 0.15s;
    }

    .doc-link:first-of-type { border-top: 1px solid var(--rule); }
    .doc-link:hover { color: var(--gold); }

    .doc-link::before {
      content: '↓';
      font-size: 0.85rem;
      color: var(--gold);
      font-weight: 600;
      flex-shrink: 0;
    }

    .doc-link-external::before {
      content: '↗';
    }

    .sponsors-section {
      padding: 48px 56px;
      border-bottom: 1px solid var(--rule);
    }

    .sponsor-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }

    .sponsor-grid a {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      border: 1px solid var(--rule);
      background: white;
      opacity: 0.8;
      transition: opacity 0.15s;
    }

    .sponsor-grid a:hover { opacity: 1; }

    .sponsor-grid img {
      width: 100%;
      height: 80px;
      object-fit: contain;
      display: block;
    }

    @media (max-width: 860px) {
      .section,
      .theme-section {
        padding: 48px 28px;
      }

      .hero-overlay { padding: 32px 28px; }
      .hero-text h2 { font-size: 2rem; }

      .keynote-grid { grid-template-columns: 1fr; }
      .keynote-image-wrap { max-width: 200px; }

      .schedule-row { grid-template-columns: 100px 1fr; }
      .dates-docs-grid { grid-template-columns: 1fr; gap: 32px; }
      .sponsors-section { padding: 40px 28px; }
    }

    @media (max-width: 560px) {
      .hero-image { height: 380px; }
      .hero-text h2 { font-size: 1.6rem; }

      .schedule-row { grid-template-columns: 1fr; }

      .schedule-time {
        border-right: none;
        border-bottom: 1px solid var(--rule);
        padding: 12px 20px;
      }
    }
  </style>

  <div class="page-body">

    <!-- Hero -->
    <section class="hero">
      <img src={hero.image} alt={hero.title} class="hero-image" />
      <div class="hero-overlay">
        <div class="hero-text">
          <p class="hero-label">ICIC 2026</p>
          <h2>{hero.title}</h2>
          <div class="hero-meta">
            <span>{hero.date}</span>
            <span>{hero.venue}</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Theme -->
    <section class="theme-section">
      <p class="section-label">Conference Theme</p>
      <h2>{theme.heading}</h2>
      <hr class="theme-rule" />
      <p>{theme.description}</p>
    </section>

    <!-- Keynote -->
    <section class="section">
      <p class="section-label">Keynote Address</p>
      <h2>Featured Speaker</h2>

      <div class="keynote-grid">
        <div class="keynote-image-wrap">
          <img src={keynote.image} alt={keynote.name} class="keynote-image" />
          <div class="keynote-image-accent"></div>
        </div>

        <div class="keynote-info">
          <h3>{keynote.name}</h3>
          <p class="keynote-role">{keynote.title}</p>
          <p class="keynote-talk-title">{keynote.talkTitle}</p>
          <p class="keynote-description">{keynote.description}</p>
        </div>
      </div>
    </section>

    <!-- Schedule -->
    <section class="section schedule-section">
      <p class="section-label">June 25, 2026</p>
      <h2>Conference Program</h2>

      <div class="schedule-list">
        {schedule.map((slot) => (
          <div class="schedule-row">
            <div class="schedule-time">{slot.time}</div>

            <div
              class="schedule-columns"
              style={`grid-template-columns: ${slot.columns.map((c) => c.width).join(" ")};`}
            >
              {slot.columns.map((column) => (
                <div class="schedule-column">
                  {column.blocks.map((block) => (
                    <div class="schedule-block">
                      <strong>{block.title}</strong>
                      {block.talkTitle ? <p><em>{block.talkTitle}</em></p> : null}
                      {block.speaker ? <p>{block.speaker}</p> : null}
                      {block.location ? <p>{block.location}</p> : null}
                    </div>
                  ))}
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Dates & Docs -->
    <section class="section">
      <div class="dates-docs-grid">
        <div>
          <p class="section-label">Deadlines</p>
          <h2>Important Dates</h2>
          {importantDates.map((item) => (
            <div class="date-item">
              <span class="date-label">{item.label}</span>
              <span class="date-value">{item.value}</span>
            </div>
          ))}
        </div>

        <div>
          <p class="section-label">Resources</p>
          <h2>Documents</h2>
          {documents.map((group) => (
            <div class="doc-group">
              <p class="doc-group-label">{group.group}</p>
              {group.items.map((doc) => (
                <a
                  href={doc.href}
                  class={`doc-link${doc.external ? ' doc-link-external' : ''}`}
                  target="_blank"
                  rel={doc.external ? 'noopener noreferrer' : ''}
                >
                  {doc.label}
                </a>
              ))}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Sponsors -->
    {sponsors.length > 0 && (
      <section class="sponsors-section">
        <div class="sponsor-grid">
          {sponsors.map((sponsor) => (
            <a href={sponsor.href} title={sponsor.name} target="_blank" rel="noopener noreferrer">
              <img src={sponsor.image} alt={sponsor.name} />
            </a>
          ))}
        </div>
      </section>
    )}

  </div>
</MainLayout>